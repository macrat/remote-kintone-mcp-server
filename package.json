{
  "name": "remote-kintone-mcp-server",
  "version": "0.1.0",
  "description": "Streamable HTTP wrapper for the kintone official MCP server.",
  "homepage": "https://github.com/macrat/remote-kintone-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/macrat/remote-kintone-mcp-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macrat/remote-kintone-mcp-server.git"
  },
  "license": "Apache-2.0",
  "author": "MacRat <m@crat.jp>",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "check": "tsc --noEmit && biome check .",
    "format": "biome check --fix ."
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@kintone/mcp-server": "1.3.8",
    "@kintone/rest-api-client": "^6.1.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "hono": "^4.7.8",
    "jose": "^6.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  }
}
