{
  "permissions": {
    "allow": [
      "Bash(npm dev:*)",
      "Bash(npm build:*)",
      "Bash(npm start:*)",
      "Bash(npm test:*)",
      "Bash(npm check:*)",
      "Bash(npm format:*)",
      "Read(.env.example)",
      "Edit(.env.example)"
    ],
    "deny": ["Read(.env)", "Edit(.env)"]
  },
  "enabledMcpjsonServers": ["kintone"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-on-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-check.sh"
          }
        ]
      }
    ]
  }
}
