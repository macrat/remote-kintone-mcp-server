# サーバーポート（デフォルト: 3000）
PORT=3000

# JWEトークン暗号化用の秘密鍵（必須、base64エンコード）
# 生成コマンド: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWE_SECRET_KEY=

# ログレベル: error, warn, info, debug（デフォルト: info）
LOG_LEVEL=info

# セッション（トークン）の有効期間（時間単位、デフォルト: 24）
SESSION_EXPIRY_HOURS=24

# HTTPリダイレクトURIを許可する場合は "true" に設定（デフォルト: false）
ALLOW_HTTP_REDIRECT=false
